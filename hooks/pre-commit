#!/bin/sh
# Factory pre-commit hook
# Enforces: completion gate (FI-7) + artifact validation
#
# Build and lint are NOT run here — they already ran during complete.ts.
# This hook only blocks commits that violate factory invariants.

set -e

# Resolve factory tooling directory from config
if command -v jq >/dev/null 2>&1 && [ -f factory.config.json ]; then
  FACTORY_DIR=$(jq -r '.factory_dir // "."' factory.config.json)
else
  FACTORY_DIR="."
fi

if [ "$FACTORY_DIR" = "." ]; then
  TOOLS_DIR="tools"
else
  TOOLS_DIR="${FACTORY_DIR}/tools"
fi

# Completion gate: started packets need completions before implementation commits
npx tsx "${TOOLS_DIR}/completion-gate.ts"

# Schema + integrity validation
npx tsx "${TOOLS_DIR}/validate.ts"
