{
  "$schema": "./schemas/factory-config.schema.json",
  "project_name": "factory",
  "factory_dir": ".",
  "verification": {
    "build": "true",
    "lint": "true",
    "test": "pnpm test"
  },
  "validation": {
    "command": "npx tsx tools/validate.ts"
  },
  "infrastructure_patterns": [
    "factory/",
    "tools/",
    "hooks/",
    "templates/",
    ".github/",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.json",
    "turbo.json",
    ".gitignore",
    ".eslintrc.json",
    ".eslintignore",
    "docs/",
    "setup.sh",
    "setup.ps1",
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "completed_by_default": {
    "kind": "agent",
    "id": "claude"
  },
  "personas": {
    "developer": {
      "description": "Implements the change",
      "instructions": [],
      "model": "opus"
    },
    "reviewer": {
      "description": "Verifies acceptance criteria are met",
      "instructions": [],
      "model": "sonnet"
    }
  }
}
