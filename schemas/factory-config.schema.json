{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factory-config.schema.json",
  "title": "Factory Config",
  "description": "Project-local configuration for Factory tooling, personas, verification, and pipeline behavior.",
  "type": "object",
  "required": [
    "project_name", "factory_dir", "artifact_dir",
    "verification", "validation", "infrastructure_patterns",
    "completed_by_default", "personas"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "project_name": { "type": "string", "minLength": 1 },
    "factory_dir": { "type": "string", "minLength": 1 },
    "artifact_dir": { "type": "string", "minLength": 1 },
    "verification": {
      "type": "object",
      "required": ["build", "lint", "test"],
      "properties": {
        "build": { "type": "string", "minLength": 1 },
        "lint": { "type": "string", "minLength": 1 },
        "test": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "infrastructure_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "completed_by_default": { "$ref": "#/$defs/identity" },
    "personas": {
      "type": "object",
      "required": ["planner", "developer", "code_reviewer", "qa"],
      "properties": {
        "planner": { "$ref": "#/$defs/persona" },
        "developer": { "$ref": "#/$defs/persona" },
        "code_reviewer": { "$ref": "#/$defs/persona" },
        "qa": { "$ref": "#/$defs/persona" }
      },
      "additionalProperties": false
    },
    "pipeline": {
      "type": "object",
      "properties": {
        "providers": {
          "type": "object",
          "properties": {
            "codex": { "$ref": "#/$defs/pipeline_provider" },
            "claude": { "$ref": "#/$defs/pipeline_provider" }
          },
          "additionalProperties": false
        },
        "persona_providers": {
          "type": "object",
          "properties": {
            "planner": { "$ref": "#/$defs/provider_name" },
            "developer": { "$ref": "#/$defs/provider_name" },
            "code_reviewer": { "$ref": "#/$defs/provider_name" },
            "qa": { "$ref": "#/$defs/provider_name" }
          },
          "additionalProperties": false
        },
        "completion_identities": {
          "type": "object",
          "properties": {
            "codex": { "$ref": "#/$defs/provider" },
            "claude": { "$ref": "#/$defs/provider" },
            "copilot": { "$ref": "#/$defs/provider" }
          },
          "additionalProperties": false
        },
        "retries": {
          "type": "object",
          "required": ["max_supervisor_ticks", "planner", "developer", "code_reviewer", "qa"],
          "properties": {
            "max_supervisor_ticks": { "type": "integer", "minimum": 1 },
            "max_transient_retries": { "type": "integer", "minimum": 0, "default": 2 },
            "planner": { "$ref": "#/$defs/retry_steps" },
            "developer": { "$ref": "#/$defs/retry_steps" },
            "code_reviewer": { "$ref": "#/$defs/retry_steps" },
            "qa": { "$ref": "#/$defs/retry_steps" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identity": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "cli", "ui"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "persona": {
      "type": "object",
      "required": ["description", "instructions"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "model": { "type": "string", "enum": ["opus", "sonnet", "haiku"] }
      },
      "additionalProperties": false
    },
    "provider_name": {
      "type": "string",
      "enum": ["codex", "claude", "copilot"]
    },
    "pipeline_provider": {
      "type": "object",
      "required": ["enabled", "command"],
      "properties": {
        "enabled": { "type": "boolean" },
        "command": { "type": "string", "minLength": 1 },
        "sandbox": { "type": "string", "enum": ["read-only", "workspace-write", "danger-full-access"] },
        "permission_mode": { "type": "string", "enum": ["acceptEdits", "auto", "bypassPermissions", "default", "dontAsk", "plan"] }
      },
      "additionalProperties": false
    }
  }
}
