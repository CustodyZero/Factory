{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supervisor-state.schema.json",
  "title": "Supervisor State",
  "description": "Persistent state for the Factory supervisor actor. Tracks feature lifecycle, escalations, and audit history. Any inference engine reads this file to resume orchestration.",
  "type": "object",
  "required": ["version", "updated_at", "updated_by", "features", "pending_escalations", "audit_log"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for forward compatibility."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last state update."
    },
    "updated_by": {
      "$ref": "#/$defs/identity",
      "description": "Identity that last updated this state."
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/feature_tracking"
      },
      "description": "Map of feature_id to tracking state."
    },
    "pending_escalations": {
      "type": "array",
      "items": { "$ref": "#/$defs/escalation" },
      "description": "Escalations awaiting human response."
    },
    "audit_log": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_entry" },
      "description": "Append-only log of supervisor decisions and actions."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identity": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["human", "agent", "cli", "ui"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "feature_tracking": {
      "type": "object",
      "required": ["feature_id", "phase", "first_seen_at", "last_tick_at", "packets_spawned", "packets_completed", "packets_accepted", "tick_count"],
      "properties": {
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": ["discovered", "executing", "blocked", "awaiting_human", "complete"],
          "description": "Current supervisor phase for this feature."
        },
        "first_seen_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the supervisor first discovered this feature."
        },
        "last_tick_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the supervisor last processed this feature."
        },
        "packets_spawned": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Packet IDs that the supervisor has dispatched for execution."
        },
        "packets_completed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Packet IDs observed as completed."
        },
        "packets_accepted": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Packet IDs observed as accepted."
        },
        "blocked_reason": {
          "type": ["string", "null"],
          "description": "Why this feature is blocked, if phase is 'blocked'."
        },
        "tick_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of times this feature has been ticked."
        }
      },
      "additionalProperties": false
    },
    "escalation": {
      "type": "object",
      "required": ["id", "kind", "feature_id", "created_at", "message", "resolved"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique escalation identifier."
        },
        "kind": {
          "type": "string",
          "enum": ["acceptance", "blocked", "failure"],
          "description": "Type of escalation."
        },
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "packet_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Packets involved in this escalation."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable explanation of what needs attention."
        },
        "resolved": {
          "type": "boolean",
          "description": "Whether this escalation has been addressed."
        },
        "resolved_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this escalation was resolved."
        }
      },
      "additionalProperties": false
    },
    "audit_entry": {
      "type": "object",
      "required": ["timestamp", "action_kind", "feature_id", "message"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "action_kind": {
          "type": "string",
          "description": "The supervisor action kind that was taken."
        },
        "feature_id": {
          "type": "string"
        },
        "packet_id": {
          "type": ["string", "null"],
          "description": "Specific packet if the action was packet-scoped."
        },
        "message": {
          "type": "string",
          "description": "Human-readable description of what happened."
        },
        "identity": {
          "$ref": "#/$defs/identity",
          "description": "Who performed this action."
        }
      },
      "additionalProperties": false
    }
  }
}
