{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feature.schema.json",
  "title": "Factory Feature",
  "description": "A high-level intent that decomposes into multiple packets. Features are the unit of planning; packets are the unit of execution. Planner-generated planned features linked to an approved intent inherit execution authority from that intent.",
  "type": "object",
  "required": ["id", "intent", "acceptance_criteria", "status", "packets", "created_by"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case unique identifier. Must match the filename (without .json)."
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "description": "What the project should do when this feature is complete."
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Testable conditions for feature delivery."
    },
    "status": {
      "type": "string",
      "enum": ["planned", "executing", "completed", "delivered"],
      "description": "Feature lifecycle status."
    },
    "packets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of packet IDs that implement this feature."
    },
    "created_by": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "cli", "ui"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "created_at": { "type": "string", "format": "date-time" },
    "intent_id": { "type": ["string", "null"], "description": "Source intent ID." },
    "planned_by": {
      "type": ["object", "null"],
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "cli", "ui"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "planned_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}
