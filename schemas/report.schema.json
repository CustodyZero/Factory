{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report.schema.json",
  "title": "Factory QA Report",
  "description": "Feature-level QA report produced after all packets are complete. Consumed by human for acceptance decisions.",
  "type": "object",
  "required": [
    "feature_id",
    "produced_at",
    "produced_by",
    "packets",
    "summary",
    "recommendation"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Must match an existing feature with all packets completed."
    },
    "produced_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of report production."
    },
    "produced_by": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["human", "agent", "cli", "ui"],
          "description": "Agent-authored reports are expected — the agent acts as QA reviewer."
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "packet_id",
          "intent_satisfied",
          "intent_summary",
          "contracts_verified",
          "risks"
        ],
        "properties": {
          "packet_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "intent_satisfied": {
            "type": "boolean",
            "description": "Explicit claim: does the deliverable match the declared intent?"
          },
          "intent_summary": {
            "type": "string",
            "minLength": 1,
            "description": "What the packet intended vs what was delivered."
          },
          "contracts_verified": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of invariants and contracts checked."
          },
          "risks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Anything the reviewer should examine."
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Feature-level QA assessment."
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept", "accept_with_reservations", "reject"],
      "description": "Advisory recommendation for the human reviewer."
    },
    "reservations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific concerns if recommendation is accept_with_reservations."
    }
  },
  "additionalProperties": false
}
