{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestrator-state.schema.json",
  "title": "Orchestrator State",
  "description": "Bounded runtime state for the deterministic factory orchestrator. Stores provider checks, small caches, and recent run records.",
  "type": "object",
  "required": ["version", "updated_at", "updated_by", "provider_health", "cache", "recent_runs"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "updated_at": { "type": "string", "format": "date-time" },
    "updated_by": { "$ref": "#/$defs/identity" },
    "provider_health": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/provider_health" }
    },
    "cache": { "$ref": "#/$defs/cache" },
    "recent_runs": {
      "type": "array",
      "items": { "$ref": "#/$defs/run_record" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identity": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["human", "agent", "cli", "ui"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "provider_health": {
      "type": "object",
      "required": ["provider", "available", "checked_at", "message"],
      "properties": {
        "provider": { "type": "string", "enum": ["codex", "claude"] },
        "available": { "type": "boolean" },
        "checked_at": { "type": "string", "format": "date-time" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "cache": {
      "type": "object",
      "required": ["plan_actions"],
      "properties": {
        "last_supervisor_action": {
          "type": ["object", "null"],
          "required": ["kind", "feature_ids", "dispatch_ids", "observed_at"],
          "properties": {
            "kind": { "type": "string" },
            "feature_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "dispatch_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "observed_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "plan_actions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["kind", "feature_id", "observed_at"],
            "properties": {
              "kind": { "type": "string" },
              "feature_id": { "type": ["string", "null"] },
              "observed_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          }
        },
        "active_run": {
          "type": ["object", "null"],
          "required": ["mode", "intent_id", "feature_id", "started_at", "tick_count"],
          "properties": {
            "mode": { "type": "string", "enum": ["plan", "supervise", "run"] },
            "intent_id": { "type": ["string", "null"] },
            "feature_id": { "type": ["string", "null"] },
            "started_at": { "type": "string", "format": "date-time" },
            "tick_count": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "recent_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/attempt_summary" }
        }
      },
      "additionalProperties": false
    },
    "run_record": {
      "type": "object",
      "required": ["id", "kind", "provider", "target_id", "started_at", "completed_at", "exit_code", "result", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["healthcheck", "planner", "packet"] },
        "provider": { "type": "string", "enum": ["codex", "claude"] },
        "target_id": { "type": "string", "minLength": 1 },
        "feature_id": { "type": ["string", "null"] },
        "dispatch_id": { "type": ["string", "null"] },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "attempt": { "type": "integer", "minimum": 1 },
        "exit_code": { "type": "integer" },
        "result": { "type": "string", "enum": ["success", "failed", "skipped"] },
        "output_path": { "type": ["string", "null"] },
        "message": { "type": "string" },
        "failure_kind": {
          "type": ["string", "null"],
          "enum": ["provider_unavailable", "provider_error", "task_failed", null]
        }
      },
      "additionalProperties": false
    },
    "attempt_summary": {
      "type": "object",
      "required": ["kind", "target_id", "persona", "provider", "model", "attempt", "outcome", "failure_kind", "observed_at"],
      "properties": {
        "kind": { "type": "string", "enum": ["planner", "packet"] },
        "target_id": { "type": "string", "minLength": 1 },
        "feature_id": { "type": ["string", "null"] },
        "dispatch_id": { "type": ["string", "null"] },
        "persona": { "type": "string", "enum": ["planner", "developer", "reviewer"] },
        "provider": { "type": "string", "enum": ["codex", "claude"] },
        "model": { "type": "string", "enum": ["opus", "sonnet", "haiku"] },
        "attempt": { "type": "integer", "minimum": 1 },
        "outcome": { "type": "string", "enum": ["success", "failed", "skipped"] },
        "failure_kind": {
          "type": ["string", "null"],
          "enum": ["provider_unavailable", "provider_error", "task_failed", null]
        },
        "observed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
