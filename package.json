{
  "name": "factory",
  "private": true,
  "version": "0.1.0",
  "description": "Change-control factory for governed AI-assisted development",
  "author": "CustodyZero (https://custodyzero.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/custodyzero/factory.git"
  },
  "type": "module",
  "scripts": {
    "factory:accept": "npx tsx tools/accept.ts",
    "factory:complete": "npx tsx tools/complete.ts",
    "factory:derive": "npx tsx tools/derive.ts",
    "factory:execute": "npx tsx tools/execute.ts",
    "factory:orchestrate": "npx tsx tools/orchestrate.ts",
    "factory:plan": "npx tsx tools/plan.ts",
    "factory:start": "npx tsx tools/start.ts",
    "factory:status": "npx tsx tools/status.ts",
    "factory:validate": "npx tsx tools/validate.ts",
    "factory:test": "vitest run",
    "test": "vitest run",
    "prepare": "git config core.hooksPath hooks"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  }
}
